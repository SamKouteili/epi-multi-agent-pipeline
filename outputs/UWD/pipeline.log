ue"], errors="coerce")\n                df_who = df_who.dropna(subset=["proxy_value"])\n                if len(df_who) > 50:\n                    proxy = df_who\n                    print(f"  SUCCESS: {len(proxy)} rows, {proxy[\'iso\'].nunique()} countries")\n        else:\n            print(f"  Status {resp.status_code}")\n    except Exception as e:\n        print(f"  Direct API failed: {e}")\n\n# Try GHO with different typhoid codes via the list endpoint\nif proxy is None or len(proxy) < 50:\n    print("\\nSearching GHO for typhoid-related indicators...")\n    try:\n        url = "https://ghoapi.azureedge.net/api/Indicator?$filter=contains(IndicatorName,\'typhoid\')"\n        resp = requests.get(url, timeout=30)\n        if resp.status_code == 200:\n            indicators = resp.json().get("value", [])\n            print(f"  Found {len(indicators)} typhoid-related indicators:")\n            for ind in indicators[:10]:\n                print(f"    {ind.get(\'IndicatorCode\')}: {ind.get(\'IndicatorName\')}")\n            \n            # Try each\n            for ind in indicators[:5]:\n                code = ind.get("IndicatorCode")\n                try:\n                    url2 = f"https://ghoapi.azureedge.net/api/{code}"\n                    resp2 = requests.get(url2, timeout=30)\n                    if resp2.status_code == 200:\n                        data2 = resp2.json()\n                        records2 = data2.get("value", [])\n                        if len(records2) > 100:\n                            df2 = pd.DataFrame(records2)\n                            df2 = df2.rename(columns={\n                                "SpatialDim": "iso",\n                                "TimeDim": "year",\n                                "NumericValue": "proxy_value"\n                            })\n                            df2 = df2[["iso", "year", "proxy_value"]].dropna()\n                            df2["year"] = pd.to_numeric(df2["year"], errors="coerce")\n         