ult\n        # -------------------------------------------------------------------\n        data_notes = "; ".join(proxy_notes)\n        data_notes += (\n            f" Analysis used {corr.n_observations} observations across {corr.n_countries} countries. "\n            "Note: True LBII (raster product) could not be obtained as country-level tabular data; "\n            "a proxy indicator was substituted (see proxy_notes)."\n        )\n        \n        summary = (\n            f"Using a substitute proxy for LBII, the bivariate correlation with SPI is "\n            f"r={corr.pearson_r:.3f} (p={corr.pearson_p:.3e}, n={corr.n_observations}). "\n        )\n        if partial is not None:\n            summary += (\n                f"After controlling for log(GDP per capita), partial r={partial.partial_r:.3f} "\n                f"(p={partial.partial_p:.3e}). "\n            )\n        summary += (\n            f"Best functional form: {form.best_form.value}. "\n            f"Verdict: {verdict.value}. "\n            "Caution: True LBII data was not available; results reflect the substitute proxy."\n        )\n        \n        result = build_result_json(\n            "SPI-H02",\n            verdict,\n            corr,\n            partial,\n            functional_form=form,\n            data_quality_notes=data_notes,\n            summary=summary,\n        )\n        result["verification_method"] = "statistical_test"\n        \n        out_file = f"{output_path}/result.json"\n        with open(out_file, "w") as f:\n            json.dump(result, f, indent=2)\n        print(f"\\n[8] Result saved to {out_file}")\n        print(json.dumps(result, indent=2))\n\nprint("\\nDone.")\n```'}, {'role': 'user', 'content': 'The script failed with return code 1.\n\n**stderr:**\n```\nWorld Bank returned unexpected payload for ER.LND.BIOM.ZS (possibly invalid code)\nWorld Bank returned unexpected payload for EN.BIO.INTIC (possibly invalid code)\nTraceback (most recent call last):\n  File "/U