orld Bank / FAO. Pesticide data had insufficient overlap. Note: this is a country-level aggregate and lacks spatial resolution for protected area catchment analysis."\n    else:\n        proxy_df = fertilizer_clean[["iso", "year", "fertilizer_kg_ha"]].copy()\n        proxy_df = proxy_df.rename(columns={"fertilizer_kg_ha": "proxy_value"})\n        proxy_col = "proxy_value"\n        proxy_notes = "Fertilizer consumption (kg/ha arable land, WB AG.CON.FERT.ZS) from World Bank / FAO. Pesticide data unavailable. Note: this is a country-level aggregate and lacks spatial resolution for protected area catchment analysis."\n\nelif pesticide is not None and not pesticide.empty:\n    print("\\nFertilizer data unavailable, using pesticide data only...")\n    pesticide_clean = pesticide.dropna(subset=["pesticide_kg_ha"])\n    proxy_df = pesticide_clean[["iso", "year", "pesticide_kg_ha"]].copy()\n    proxy_df = proxy_df.rename(columns={"pesticide_kg_ha": "proxy_value"})\n    proxy_col = "proxy_value"\n    proxy_notes = "Pesticide use (WB AG.CON.PEST.ZS) from World Bank / FAO. Fertilizer data unavailable."\n\nelse:\n    print("\\nBoth fertilizer and pesticide World Bank data unavailable.")\n    print("Attempting to use FAO data via alternative source...")\n    \n    # Try FAO FAOSTAT API for fertilizer use\n    try:\n        fao_url = "https://fenix.fao.org/faostat/api/v1/en/data/RFN?area=&element=5157&item=3102&year=2010,2011,2012,2013,2014,2015,2016,2017,2018,2019,2020&output_type=csv"\n        resp = requests.get(fao_url, timeout=30)\n        if resp.status_code == 200:\n            print("  FAO FAOSTAT data fetched")\n        else:\n            print(f"  FAO FAOSTAT returned status {resp.status_code}")\n    except Exception as e:\n        print(f"  FAO FAOSTAT fetch failed: {e}")\n\n# If no proxy data available, write inconclusive result\nif proxy_df is None or proxy_df.empty:\n    print("\\nNo proxy data available. Writing inconclusive result...")\n    \n    result = {\n      