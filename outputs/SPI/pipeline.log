ersity/lbii-country-data/main/lbii_country.csv",\n        "https://data.nhm.ac.uk/dataset/lbii/resource/country_lbii.csv",\n    ]\n    for url in urls_to_try:\n        try:\n            resp = requests.get(url, timeout=15)\n            if resp.status_code == 200:\n                from io import StringIO\n                df_lbii = pd.read_csv(StringIO(resp.text))\n                print(f"    SUCCESS: Downloaded from {url}, shape={df_lbii.shape}")\n                print(f"    Columns: {list(df_lbii.columns)}")\n                # Try to standardize\n                proxy = df_lbii\n                proxy_notes.append(f"Downloaded LBII from {url}")\n                break\n        except Exception as e:\n            print(f"    Failed {url}: {e}")\n\n# --- Attempt C: Try Natural Capital Index or Forest landscape integrity ---\nif proxy is None:\n    print("    [C] Trying Forest Landscape Integrity Index as LBII proxy...")\n    try:\n        # Forest landscape integrity (Grantham et al.) is close to intactness\n        df_flii = fetch_world_bank_indicator("EN.BIO.INTIC.ZS")\n        if df_flii is not None and len(df_flii) > 50:\n            proxy = df_flii.rename(columns={"value": "proxy_value"})\n            proxy_notes.append("Used EN.BIO.INTIC.ZS as LBII proxy.")\n            print(f"    SUCCESS: {len(proxy)} records")\n    except Exception as e:\n        print(f"    Failed: {e}")\n\n# --- Attempt D: Use mean area protected in important biodiversity sites (BII-correlated) ---\nif proxy is None:\n    print("    [D] Trying EN.CLC.MDAT.ZS (protected area coverage in important biodiversity sites)...")\n    try:\n        df_d = fetch_world_bank_indicator("EN.CLC.MDAT.ZS")\n        if df_d is not None and len(df_d) > 100:\n            proxy = df_d.rename(columns={"value": "proxy_value"})\n            proxy_notes.append("Used EN.CLC.MDAT.ZS (mean area protected in important bio sites) as closest WB proxy.")\n            print(f"    SUCCESS: {len(proxy)} records")\n    except Exception as e:\n        print(f"    Failed: {e}")\n\n# --- Attempt E: Broader WB search ---\nif proxy is None:\n    print("    [E] Broader search for biodiversity intactness indicators...")\n    try:\n        results = search_world_bank("biodiversity intactness habitat")\n        print(f"    Found {len(results)} results")\n        if len(results) > 0:\n            print(f"    Top results: {results[:5]}")\n    except Exception as e:\n        print(f"    Search failed: {e}")\n\n# --- Attempt F: Try Human Footprint / Land Use Pressure as inverse proxy ---\nif proxy is None:\n    print("    [F] Trying Human Footprint / Land Use Pressure (inverse LBII proxy)...")\n    try:\n        # AG.LND.AGRI.ZS = agricultural land % — inverse of intactness\n        df_agri = fetch_world_bank_indicator("AG.LND.AGRI.ZS")\n        if df_agri is not None and len(df_agri) > 200:\n            df_agri["proxy_value"] = 100 - df_agri["value"]  # invert: less agriculture = more intactness\n            proxy = df_agri[["iso", "year", "proxy_value"]]\n            proxy_notes.append(\n                "LBII data not available as tabular country data. "\n                "Used (100 - agricultural land %) as a rough inverse proxy for land use pressure/intactness. "\n                "Note: This is a very indirect proxy."\n            )\n            print(f"    SUCCESS: {len(proxy)} records (using inverse of agricultural land %)")\n    except Exception as e:\n        print(f"    Failed: {e}")\n\n# -------------------------------------------------------------------\n# 3. Merge and analyze\n# -------------------------------------------------------------------\nif proxy is None:\n    print("\\n[!] All proxy data acquisition attempts failed.")\n    print("    Writing INCONCLUSIVE result...")\n    \n    result = {\n        "hypothesis_id": "SPI-H02",\n        "verdict": "inconclusive",\n        "verification_method": "statistical_test",\n        "data_quality_notes": (\n            "LBII (Local Biodiversity Intactness Index) is distributed as a 1km raster/GeoTIFF "\n            "and no tabular country-level version was accessible. "\n            "Attempted: (1) World Bank API for LBII-related indicators, "\n            "(2) Direct URL downloads from NatureMap/PREDICTS repositories, "\n            "(3) Alternative biodiversity indicators. "\n            "None returned sufficient country-level tabular data for correlation analysis."\n        ),\n        "summary": (\n            "Unable to verify SPI-H02 due to data inaccessibility. "\n            "LBII is available only as a global raster product; no country-level aggregated "\n            "version was found via accessible APIs or open data repositories."\n        ),\n    }\n    \n    out_file = f"{output_path}/result.json"\n    with open(out_file, "w") as f:\n... [truncated] ...\n```\n\nReview the above and return your quality annotation as a JSON object.\n'}], 'model': 'claude-haiku-4-5-20251001', 'system': 'You are a quality-assurance reviewer for the EPI Proxy Discovery Pipeline.\n\nYou receive the outputs of a verification agent that tested a proxy hypothesis.\nYour job is to review the agent\'s work and produce a structured quality annotation.\nYou do NOT override the verdict — you only flag potential issues.\n\n## 6-Point Checklist\n\nFor each point, set the boolean to false if you detect a problem:\n\n1. **no_synthetic_data** (default true): Set to false if the verify.py script generates\n   fake/simulated proxy data using np.random, random, synthetic formulas, or hardcoded arrays\n   instead of fetching real data. Loading from CSV/API is fine.\n\n2. **year_alignment_ok** (default true): Set to false if proxy and target data are joined\n   on mismatched years — e.g., using 2020 proxy values matched against 2010 target values,\n   or broadcasting a single year of proxy data across all target years. This is about\n   proxy-to-target temporal alignment, NOT about whether the data covers the full time\n   range in the hypothesis. If the available data is narrower than the hypothesis\'s\n   time_period but proxy and target years match correctly, that is fine.\n\n3. **hypothesis_interpretation_ok** (default true): Set to false if the agent tested a\n   materially different proxy variable than what the hypothesis specified (not just a\n   reasonable substitution, but a conceptually different variable).\n\n4. **data_source_authentic** (default true): Set to false if the proxy data did not come\n   from the source specified in the hypothesis and the substitution was not documented\n   in data_quality_notes.\n\n5. **country_coverage_adequate** (default true): Set to false if the merged dataset has\n   fewer than 15 countries or fewer than 20 observations, making statistical conclusions\n   unreliable.\n\n6. **outlier_concerns** (default false): Set to true if there are signs of extreme outlier\n   influence — e.g., a single country driving the entire correlation, or the script does\n   not handle obvious outliers in the data.\n\n## Mechanistic Explanation\n\nWrite 2-3 sentences explaining the causal mechanism connecting the proxy to the target\nindicator. This should be a clear narrative, not a statistical summary. If the mechanism\nis implausible, say so.\n\n## Output Format\n\nReturn a single JSON object (NO markdown fences, NO commentary outside the JSON):\n{\n  "no_synthetic_data": true/false,\n  "year_alignment_ok": true/false,\n  "hypothesis_interpretation_ok": true/false,\n  "data_source_authentic": true/false,\n  "country_coverage_adequate": true/false,\n  "outlier_concerns": true/false,\n  "mechanistic_explanation": "2-3 sentence causal narrative",\n  "issues": ["list of specific issues found, empty if clean"],\n  "overall_assessment": "clean | minor_issues | major_issues"\n}\n'}}
