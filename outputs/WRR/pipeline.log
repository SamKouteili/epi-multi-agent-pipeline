e references combustion facilities and energy recovery.")\n    else:\n        print(f"  EPA page returned status {r.status_code}")\n        citation_notes.append(f"EPA page HTTP {r.status_code}.")\nexcept Exception as e:\n    print(f"  Could not reach EPA URL: {e}")\n    citation_notes.append(f"EPA URL not reachable: {e}")\n\n# Statista is a paid service — note this\ncitation_notes.append(\n    "Statista URL (primary source) requires paid subscription; data not directly accessible."\n)\nprint("  Statista is a paid/subscription service — cannot download directly.")\n\n# ─────────────────────────────────────────────────────────────\n# Step 2: Attempt to find proxy data via World Bank / alternatives\n# ─────────────────────────────────────────────────────────────\nprint("\\n[Step 2] Searching for proxy data...")\n\n# Load EPI target\nprint("  Loading WRR target indicator...")\ntarget = load_raw_indicator("WRR")\nprint(f"  WRR target: {len(target)} rows, {target[\'iso\'].nunique()} countries")\n\nproxy_df = None\ndata_source_used = None\n\n# Try World Bank indicators related to waste-to-energy / waste treatment\nwb_candidates = [\n    ("EN.WWT.WWTR.ZS", "Proportion of wastewater safely treated (%)"),\n    ("EN.MA.IGSM.ZS", "Proportion of population w/ solid waste collection"),\n    ("IS.AIR.GOOD.MT.K1", "Air transport, registered carrier departures worldwide"),  # unrelated\n]\n\n# More targeted search\nprint("  Searching World Bank for waste incineration/energy recovery indicators...")\ntry:\n    results = search_world_bank("waste incineration energy recovery")\n    if results:\n        print(f"  Found {len(results)} WB indicators for \'waste incineration energy recovery\':")\n        for r in results[:5]:\n            print(f"    {r}")\nexcept Exception as e:\n    print(f"  WB search failed: {e}")\n\ntry:\n    results2 = search_world_bank("municipal solid waste treatment")\n    if results2:\n        print(f"  Found {len(results2)} WB indicators for \'municipal solid waste treatment\':")\n        for r in results2[:5]:\n            print(f"    {r}")\nexcept Exception as e:\n    print(f"  WB search failed: {e}")\n\n# Try fetching the most relevant WB indicators for waste management\n# EN.MA.IGSM.ZS = Population with managed waste (proxy for waste infrastructure)\nprint("\\n  Attempting to fetch WB municipal solid waste indicators...")\n\nwaste_indicators = [\n    "EN.MA.IGSM.ZS",   # Municipal Solid Waste - collected\n    "SH.STA.HYGN.ZS",  # Handwashing/sanitation\n    "EN.WWT.WWTR.ZS",  # Wastewater treatment (closest infrastructure proxy)\n]\n\nfor code in waste_indicators:\n    try:\n        print(f"  Trying WB indicator: {code}")\n        df = fetch_world_bank_indicator(code)\n        if df is not None and len(df) > 100:\n            print(f"    Got {len(df)} rows for {code}")\n            proxy_df = df.rename(columns={"value": "proxy_value"})\n            data_source_used = f"World Bank indicator {code}"\n            break\n        else:\n            print(f"    Insufficient data for {code}")\n    except Exception as e:\n        print(f"    Failed for {code}: {e}")\n\n# If WB failed, try a broader search\nif proxy_df is None:\n    print("\\n  Trying broader WB search for waste management capacity...")\n    try:\n        res = search_world_bank("waste management recycling")\n        print(f"  Results: {res[:5] if res else \'None\'}")\n    except Exception as e:\n        print(f"  Search failed: {e}")\n\n# ─────────────────────────────────────────────────────────────\n# Step 3: If we have proxy data, run statistics; otherwise accept on literature\n# ─────────────────────────────────────────────────────────────\nprint("\\n[Step 3] Determining verdict...")\n\nif proxy_df is not None and len(proxy_df) > 0:\n    print(f"  Using proxy: {data_source_used}")\n    \n    # Merge with target\n    merged = target.merge(proxy_df[["iso", "year", "proxy_value"]], on=["iso", "year"])\n    merged = merged.dropna(subset=["value", "proxy_value"