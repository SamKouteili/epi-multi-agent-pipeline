p 4: Write results\n# -----------------------------------------------------------------------\noutput_file = f"{output_path}/result.json"\nprint(f"\\n[Step 4] Writing results to {output_file}...")\n\nwith open(output_file, "w") as f:\n    json.dump(result, f, indent=2, default=str)\n\nprint(f"✓ Results written to {output_file}")\nprint(f"\\nFinal verdict: {result[\'verdict\']}")\nprint(f"Verification method: {result[\'verification_method\']}")\nprint("\\nDone.")\n```'}, {'role': 'user', 'content': 'The script failed with return code 1.\n\n**stderr:**\n```\nTraceback (most recent call last):\n  File "/opt/miniconda3/envs/epi/lib/python3.11/site-packages/pandas/core/indexes/base.py", line 3641, in get_loc\n    return self._engine.get_loc(casted_key)\n           ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n  File "pandas/_libs/index.pyx", line 168, in pandas._libs.index.IndexEngine.get_loc\n  File "pandas/_libs/index.pyx", line 197, in pandas._libs.index.IndexEngine.get_loc\n  File "pandas/_libs/hashtable_class_helper.pxi", line 7668, in pandas._libs.hashtable.PyObjectHashTable.get_item\n  File "pandas/_libs/hashtable_class_helper.pxi", line 7676, in pandas._libs.hashtable.PyObjectHashTable.get_item\nKeyError: \'p-val\'\n\nThe above exception was the direct cause of the following exception:\n\nTraceback (most recent call last):\n  File "/Users/samkouteili/rose/epi/multi-agent/outputs/WRR/stage2/WRR-H05/verify.py", line 172, in <module>\n    partial = run_partial_correlation(\n              ^^^^^^^^^^^^^^^^^^^^^^^^\n  File "/Users/samkouteili/rose/epi/multi-agent/src/utils/stats.py", line 99, in run_partial_correlation\n    partial_p=float(result["p-val"].iloc[0]),\n                    ~~~~~~^^^^^^^^^\n  File "/opt/miniconda3/envs/epi/lib/python3.11/site-packages/pandas/core/frame.py", line 4378, in __getitem__\n    indexer = self.columns.get_loc(key)\n              ^^^^^^^^^^^^^^^^^^^^^^^^^\n  File "/opt/miniconda3/envs/epi/lib/python3.11/site-packages/pandas/core/indexes/base.py