ue/false,\n  "outlier_concerns": true/false,\n  "mechanistic_explanation": "2-3 sentence causal narrative",\n  "issues": ["list of specific issues found, empty if clean"],\n  "overall_assessment": "clean | minor_issues | major_issues"\n}\n'}}
