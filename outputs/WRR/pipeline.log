t("\\n  Trying World Bank: EN.H2O.WATR.ZS (wastewater treatment %)...")\ntry:\n    proxy_df = fetch_world_bank_indicator("EN.H2O.WATR.ZS")\n    if proxy_df is not None and len(proxy_df) > 50:\n        proxy_df = proxy_df.rename(columns={"value": "proxy_value"})\n        proxy_source = "WB EN.H2O.WATR.ZS: Wastewater treated (%)"\n        print(f"  SUCCESS: {len(proxy_df)} rows, {proxy_df[\'iso\'].nunique()} countries")\n    else:\n        print(f"  Insufficient data: {len(proxy_df) if proxy_df is not None else 0} rows")\n        proxy_df = None\nexcept Exception as e:\n    print(f"  Failed: {e}")\n    proxy_df = None\n\n# Try alternative WB indicator for safely managed sanitation (related to treatment)\nif proxy_df is None:\n    print("\\n  Trying World Bank: SH.STA.SMSS.ZS (safely managed sanitation)...")\n    try:\n        proxy_df = fetch_world_bank_indicator("SH.STA.SMSS.ZS")\n        if proxy_df is not None and len(proxy_df) > 50:\n            proxy_df = proxy_df.rename(columns={"value": "proxy_value"})\n            proxy_source = "WB SH.STA.SMSS.ZS: People using safely managed sanitation services (%)"\n            print(f"  SUCCESS: {len(proxy_df)} rows, {proxy_df[\'iso\'].nunique()} countries")\n        else:\n            print(f"  Insufficient data: {len(proxy_df) if proxy_df is not None else 0} rows")\n            proxy_df = None\n    except Exception as e:\n        print(f"  Failed: {e}")\n        proxy_df = None\n\n# Try SDG 6.3.1: Safely treated wastewater\nif proxy_df is None:\n    print("\\n  Trying World Bank: SH.STA.WASH.P5 (WASH)...")\n    try:\n        proxy_df = fetch_world_bank_indicator("SH.STA.WASH.P5")\n        if proxy_df is not None and len(proxy_df) > 50:\n            proxy_df = proxy_df.rename(columns={"value": "proxy_value"})\n            proxy_source = "WB SH.STA.WASH.P5: WASH indicator"\n            print(f"  SUCCESS: {len(proxy_df)} rows, {proxy_df[\'iso\'].nunique()} countries")\n        else:\n            print(f"  Insufficient data")