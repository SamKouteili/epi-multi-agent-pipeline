de Flows vs WRR ===\\n")\n\n# ── 1. Load EPI target ──────────────────────────────────────────────────────\nprint("Loading WRR target indicator...")\ntarget = load_raw_indicator("WRR")\nprint(f"  WRR: {len(target)} rows, {target[\'iso\'].nunique()} countries, years {target[\'year\'].min()}-{target[\'year\'].max()}")\n\n# ── 2. Acquire proxy data ────────────────────────────────────────────────────\n# UN Comtrade requires authentication for bulk downloads.\n# We will use World Bank proxy indicators for recycling / waste trade:\n#   EN.POP.EL5M.ZS = not relevant\n#   We\'ll try several WB trade/waste indicators as proxies for recycled material trade flows.\n#\n# Best available proxies from World Bank:\n#   - Waste generation / recycling related indicators\n#   - Since direct recycled material trade flows (HS codes 3915, 7204, 4707, etc.)\n#     are not available via WB API, we use the closest available proxy:\n#     "Municipal solid waste treated/recycled" from WB environment indicators\n#\n# Strategy:\n#   1. Try WB indicator EN.POP.EL5M.ZS (not relevant, skip)\n#   2. Try searching for recycling/waste trade indicators\n#   3. If not found, use exports of goods/services as proportion of GDP as\n#      a very rough proxy (will likely be inconclusive)\n#   4. Document all attempts\n\nproxy = None\nproxy_name = None\nproxy_notes = []\n\n# Attempt 1: Search World Bank for recycling indicators\nprint("\\nSearching World Bank for recycled material trade indicators...")\ntry:\n    results = search_world_bank("recycled waste materials trade")\n    if results:\n        print(f"  Found {len(results)} results:")\n        for r in results[:10]:\n            print(f"    {r.get(\'id\',\'?\')} — {r.get(\'name\',\'?\')}")\nexcept Exception as e:\n    print(f"  Search failed: {e}")\n    proxy_notes.append(f"WB search failed: {e}")\n\n# Attempt 2: Try specific WB waste/recycling indicators\nprint("\\nAttempting to fetch specific World Bank waste/recycling indicators...")\nwb_candidate