URL patterns\nprint("\\nAttempt 6: Trying ITU/UNEP data sources...")\nitu_urls = [\n    "https://rawdata.itu.int/itu-d/ict/statistics/",\n    "https://opendata.itu.int/",\n]\n\n# Attempt 7: Try World Bank "Waste collection coverage rate" \nprint("\\nAttempt 7: Trying specific waste collection WB codes...")\nspecific_codes = [\n    "EN.URB.MCTY.TL.ZS",\n    "SH.STA.HYGN.ZS",  # Handwashing - sanitation proxy\n    "SH.H2O.SMDW.ZS",  # Safely managed drinking water\n    "SH.STA.SMSS.ZS",  # Safely managed sanitation\n    "SH.STA.BASS.ZS",  # Basic sanitation\n]\n\nfor code in specific_codes:\n    try:\n        print(f"  Trying {code}...")\n        df = fetch_world_bank_indicator(code)\n        if df is not None and len(df) > 100:\n            print(f"  Got data: {len(df)} rows, {df[\'iso\'].nunique()} countries")\n            # Only use as proxy if not already tested\n            if proxy is None:\n                # Let\'s use safely managed sanitation as a broad infrastructure proxy\n                proxy = df.rename(columns={"value": "proxy_value"})\n                proxy_source = f"World Bank: {code}"\n                data_quality_notes = (\n                    f"E-waste recycling rate data from Global E-waste Monitor 2024 could not be "\n                    f"accessed directly (PDF-based report). Substituted with World Bank {code} "\n                    f"(sanitation/water access indicator) as a proxy for waste management "\n                    f"infrastructure quality. This is an imperfect substitute for e-waste recycling rates."\n                )\n                break\n    except Exception as e:\n        print(f"  Failed: {e}")\n\n# If we still have no proxy, report inconclusive\nif proxy is None:\n    print("\\nNo suitable proxy data found. Reporting inconclusive...")\n    data_quality_notes = (\n        "Attempted to access e-waste recycling rate data from: "\n        "1) Global E-waste Monitor 2024 (ITU/UNITAR) - PDF report, no direct CSV/API access; "\n    