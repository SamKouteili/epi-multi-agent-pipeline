la/5.0"})\n        status = resp.status_code\n        content_len = len(resp.text)\n        print(f"  URL: {url}")\n        print(f"    → Status: {status}, Content length: {content_len} chars")\n        if status == 200 and content_len > 500:\n            citation_notes.append(f"URL accessible (HTTP {status}): {url}")\n            # Check for key claims in content\n            content_lower = resp.text.lower()\n            if "mrf" in content_lower or "recycl" in content_lower or "robot" in content_lower:\n                print(f"    → Relevant keywords found (MRF/recycl/robot)")\n                citation_notes.append(f"  - Relevant MRF/recycling/robotics content confirmed")\n        else:\n            citation_notes.append(f"URL returned HTTP {status}: {url}")\n    except Exception as e:\n        print(f"  URL fetch failed: {url} → {e}")\n        citation_notes.append(f"URL not accessible: {url} ({e})")\n\nprint("\\nCitation check complete.")\n\n# -----------------------------------------------------------------------\n# Step 2: Attempt to find proxy data\n# -----------------------------------------------------------------------\nprint("\\n[Step 2] Searching for proxy data on MRF automation / robotics adoption...")\n\n# The hypothesis is about proportion of MRFs with AI/robotic sorting equipment.\n# This is a very niche industry metric without systematic global databases.\n# We\'ll try several approaches:\n\nproxy_found = False\nproxy_df = None\ndata_source_used = None\n\n# Attempt 2a: World Bank - search for recycling technology or MRF-related data\nprint("\\n  [2a] Searching World Bank for MRF/automation-related indicators...")\ntry:\n    results = search_world_bank("material recovery facility automation recycling")\n    print(f"  WB search results: {results[:3] if len(results) > 0 else \'none\'}")\nexcept Exception as e:\n    print(f"  WB search failed: {e}")\n\n# Attempt 2b: Try World Bank recycling/waste management related indicators\nprint("\\n  [2b] Trying World Bank waste/recycling indicators as proxies...")\nwb_candidates = [\n    ("EN.WWT.WWTP.ZS", "share of wastewater treated"),  # water, not waste\n    ("IS.ROD.DNST.K2", "road density"),  # no\n]\n\n# More targeted: try manufacturing/industrial technology adoption\n# or high-tech exports as proxy for industrial automation capacity\nprint("\\n  [2c] Trying high-tech manufacturing / industrial robot density as proxy...")\n\n# International Federation of Robotics (IFR) data is not on World Bank.\n# Let\'s try World Bank manufacturing value added or technology indicators\ntech_indicators = [\n    "NV.MNF.TECH.ZS.UN",   # medium/high-tech manufacturing\n    "GB.XPD.RSDV.GD.ZS",   # R&D expenditure\n    "IP.PAT.RESD",          # patent applications by residents\n]\n\nfor wb_code in tech_indicators:\n    try:\n        df = fetch_world_bank_indicator(wb_code)\n        if df is not None and len(df) > 50:\n            print(f"  ✓ Found WB indicator {wb_code}: {len(df)} rows")\n            proxy_df = df.rename(columns={"value": "proxy_value"})\n            data_source_used = f"World Bank {wb_code} (technology/innovation proxy)"\n            proxy_found = True\n            break\n        else:\n            print(f"  ✗ WB indicator {wb_code}: insufficient data")\n    except Exception as e:\n        print(f"  ✗ WB indicator {wb_code} failed: {e}")\n\n# Attempt 2d: Try industrial robotics density from World Bank\nif not proxy_found:\n    print("\\n  [2d] Trying \'industrial robots\' or automation-related WB search...")\n    try:\n        results = search_world_bank("industrial robots automation manufacturing technology")\n        if results:\n            print(f"  Search results: {results[:5]}")\n    except Exception as e:\n        print(f"  Search failed: {e}")\n\n# Attempt 2e: Try manufacturing automation via UNIDO or similar\nif not proxy_found:\n    print("\\n  [2e] Checking for UNIDO/manufacturing data via WB proxies...")\n    # MVA (Manufacturing Value Added) as % of GDP can proxy for industrial capacity\n    try:\n        df = fetch_world_bank_indicator("NV.IND.MANF.ZS")\n        if df is not None and len(df) > 100:\n            print(f"  ✓ Manufacturing value added (% GDP): {len(df)} rows")\n            proxy_df = df.rename(columns={"value": "proxy_value"})\n            data_source_used = "World Bank NV.IND.MANF.ZS - Manufacturing value added (% of GDP)"\n            proxy_found = True\n    except Exception as e:\n        print(f"  ✗ Manufacturing VA failed: {e}")\n\n# If we found a proxy, try to correlate with WRR\nif proxy_found and proxy_df is not None:\n    print(f"\\n[Step 3] Proxy found: {data_source_used}")\n    print(f"  Proxy data shape: {proxy_df.shape}")\n    \n    # Load EPI target\n    print("\\n[Step 3] Loading WRR target data...")\n    target = load_raw_indicator("WRR")\n    print(f"  WRR target: {len(target)} rows, {target[\'iso\'].nunique()} countries")\n    \n    # Merge\n    merged = target.merge(proxy_df[["iso", "year", "proxy_value"]], on=["iso", "year"])\n    merged = merged.dropna(subset=["value", "proxy_value"])\n    print(f"  Merged dataset: {len(merged)} rows, {merged[\'iso\'].nunique()} countries")\n    \n    if len(merged) >= 20:\n        # Bivariate correlation\n        corr = run_bivariate_correlation(\n            merged["proxy_value"], merged["value"], iso=merged["iso"]\n        )\n        print(f"\\n  Pearson r = {corr.pearson_r:.4f}, p = {corr.pearson_p:.4f}")\n        print(f"  Spearman rho = {corr.spearman_rho:.4f}, p = {corr.spearman_p:.4f}")\n        print(f"  N = {corr.n_observations}, Countries = {corr.n_countries}")\n        \n        # Partial correlation controlling for GDP per capita\n        gpc = load_raw_indicator("GPC")\n        merged_gpc = merged.merge(\n            gpc[["iso", "year", "value"]].rename(columns={"value": "gpc"}),\n            on=["iso", "year"]\n        )\n        merged_gpc = merged_gpc.dropna(subset=["gpc"])\n        merged_gpc["log_gpc"] = np.log(merged_gpc["gpc"]